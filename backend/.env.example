ENVIRONMENT=development
DEBUG=true
# Docker Compose uses host "db"; local Postgres uses localhost
DATABASE_URL=postgresql+asyncpg://aed:aed@localhost:5432/aed_locator
SECRET_KEY=generate-a-long-random-secret
CORS_ORIGINS=["http://localhost:5173"]
ADMIN_EMAILS=["admin@aedlocator.local"]
RATE_LIMIT_REPORTS=5/minute
UPLOAD_DIR=uploads
GOOGLE_MAPS_API_KEY=
