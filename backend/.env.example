ENVIRONMENT=development
DEBUG=true
# Docker Compose uses host "db"; local Postgres uses localhost
DATABASE_URL=postgresql+asyncpg://aed:aed@localhost:5432/aed_locator
SECRET_KEY=generate-a-long-random-secret
CORS_ORIGINS=["http://localhost:5173"]
ADMIN_EMAILS=["admin@aedlocator.local"]
RATE_LIMIT_REPORTS=5/minute

# Storage: local (default) or gcs
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# GCS (development bucket names; production uses aed-locator-prod-* via env)
GCS_TEMP_BUCKET=aed-locator-dev-inbox
GCS_IMAGES_BUCKET=aed-locator-dev-aed-images
GCS_SIGNED_UPLOAD_TTL_SECONDS=900
GCS_SIGNED_READ_TTL_SECONDS=3600
GCS_IMAGE_PREFIX=aed-images
IMAGE_PROCESSOR_URL=
MAX_IMAGE_BYTES=10485760
MAX_IMAGES_PER_SUBMISSION=5
MIN_IMAGES_NEW_LOCATION=1
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

GOOGLE_MAPS_API_KEY=
